    "code": "ip = row['ip']\nfull_addr = row['full_addr']\naccess_type = row['type']\n\n# Extract page indices (relational, no magic)\nip_page = ip >> 12\naddr_page = full_addr >> 12\nsame_page = ip_page == addr_page\n\n# Address delta for locality detection\naddr_delta = abs(full_addr - ip) if ip != 0 else full_addr\n\n# Bitwise similarity between ip and address\nip_addr_xor = ip ^ full_addr\nxor_popcount = bin(ip_addr_xor).count('1')\n\n# Access type flags\nis_prefetch = access_type == 2\nis_rfo = access_type == 1\nis_load = access_type == 0\nis_translation = access_type == 4\n\nscore = 0.0\n\n# Primary signal: same page = strong reuse indicator\nif same_page:\n    score += 2.0\nelse:\n    # Different page: penalize based on XOR popcount ratio\n    xor_ratio = xor_popcount / 64.0\n    score -= xor_ratio\n\n# Secondary: address delta (small = good locality)\nif addr_delta > 0:\n    delta_bits = len(bin(addr_delta)) - 2\n    # Normalize by typical cache line size and page size\n    if delta_bits < 10:\n        score += 1.5\n    elif delta_bits < 20:\n        score += 0.8\n    elif delta_bits < 32:\n        score += 0.2 - (delta_bits - 20) / 120.0\n    else:\n        score -= 0.5\n\n# Tertiary: bitwise overlap (low XOR = similar addresses)\nif xor_popcount < 10:\n    score += 1.0\nelif xor_popcount < 32:\n    score += 0.4 - (xor_popcount - 10) / 110.0\n\n# Access type patterns\nif is_load:\n    score += 0.3\nelif is_prefetch:\n    score -= 0.8\nelif is_rfo:\n    score -= 0.2\nelif is_translation:\n    score -= 0.4\n\n# Edge cases\nif ip == 0 or full_addr == 0:\n    score -= 0.5\n\nreturn score",
